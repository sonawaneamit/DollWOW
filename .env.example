NEXT_PUBLIC_SITE_URL=https://dollwow.com
ADMIN_APP_URL=https://doll-wow.vercel.app

# Shopify
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CHECKOUT_DOMAIN=checkout.dollwow.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
# Optional override. If omitted, server-side Admin calls can mint a short-lived token
# from SHOPIFY_CLIENT_ID and SHOPIFY_CLIENT_SECRET.
SHOPIFY_ADMIN_ACCESS_TOKEN=
# JSON map of custom option charge denominations to published Shopify variant IDs.
# Example: {"500":"gid://shopify/ProductVariant/...","100":"gid://shopify/ProductVariant/...","50":"gid://shopify/ProductVariant/...","10":"gid://shopify/ProductVariant/...","5":"gid://shopify/ProductVariant/...","1":"gid://shopify/ProductVariant/..."}
SHOPIFY_CUSTOM_OPTION_CHARGE_VARIANTS=
SHOPIFY_CUSTOM_OPTION_CHARGE_CURRENCY=USD
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_APP_AUTOMATION_TOKEN=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI and analytics
OPENAI_API_KEY=
OPENAI_VISUAL_SEARCH_MODEL=gpt-4.1-mini
EMAIL_PROVIDER_API_KEY=
ADMIN_ALERT_EMAIL=hello@dollwow.com
ADMIN_ALERT_FROM=hello@dollwow.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
ADMIN_BASIC_AUTH_USERNAME=
ADMIN_BASIC_AUTH_PASSWORD=
GA_MEASUREMENT_ID=

# Crawlers/imports
APIFY_API_TOKEN=
APIFY_WEB_SCRAPER_ACTOR_ID=apify~web-scraper
APIFY_GOOGLE_LENS_ACTOR_ID=borderline~google-lens

# SEO enrichment
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
